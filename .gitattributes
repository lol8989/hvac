# 기본: 텍스트 파일은 Git이 자동 판별하고 저장소에는 LF로 정규화한다.
* text=auto eol=lf

# 명시적으로 텍스트로 다루는 소스/설정 파일 (LF)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows 전용 스크립트는 CRLF 유지
*.bat   text eol=crlf
*.cmd   text eol=crlf

# 바이너리/오피스 문서는 diff/정규화 대상에서 제외
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.docx  binary
*.doc   binary
*.pptx  binary
*.zip   binary
